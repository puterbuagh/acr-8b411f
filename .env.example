# Supabase project URL (shared instance)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe for browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Isolated Postgres schema name for this project (required, shared-schema mode)
SUPABASE_SCHEMA=acr

# Mirror of SUPABASE_SCHEMA exposed to the browser for client-side Supabase calls
NEXT_PUBLIC_SUPABASE_SCHEMA=acr

# Supabase service-role key (server-only, never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
